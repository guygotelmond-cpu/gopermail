FROM golang:1.26-alpine AS build
ENV GOTOOLCHAIN=auto
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/controld ./cmd/controld

FROM alpine:3.20
COPY --from=build /out/controld /usr/local/bin/controld
EXPOSE 9090
ENTRYPOINT ["/usr/local/bin/controld"]
